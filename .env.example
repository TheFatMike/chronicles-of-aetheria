# Chronicles of Aetheria Environment Template
# Rename this file to .env and fill in the values

# Redis Connection (Format: redis://:password@host:port)
REDIS_URL=redis://localhost:6379

# Firebase Service Account (JSON string)
FIREBASE_SERVICE_ACCOUNT=

# Server Config
PORT=3000
WIPE_DATABASE=false

# Owner Permissions: Comma-separated list of emails with full ownership access
OWNER_EMAILS=owner@example.com,dev@example.com
